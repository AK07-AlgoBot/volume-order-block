# Copy this file to the repository root as `.env` (Docker Compose loads `../.env` from configs/docker-compose.yml).

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

# First-time seed only: if users_auth.json has no AK07 row yet, this sets the password hash.
# Data volume path: src/server/data/users_auth.json
AK07_PASSWORD=change-me-rotate-for-production

BOT_API_TOKEN=change-me-shared-secret-for-trading-bot

# Used by the trading bot to POST dashboard updates; compose sets DASHBOARD_API_BASE for the bot service.
# DASHBOARD_API_BASE=http://api:8000
# BOT_CREDENTIALS_POLL_SECONDS=60
# Trading day end in IST; bot auto-shutdown/archive starts after this time (HH:MM).
# TRADING_DAILY_SHUTDOWN_TIME=23:21

# Include Vite dev origin if the dashboard is opened on :5173 (direct API calls) or after OAuth.
DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://ak07.in,http://ak07.in,http://localhost:8080,http://127.0.0.1:8080

# Kite Connect (dashboard "Connect with Zerodha" + OAuth callback). Redirect URL in Kite app must match exactly.
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_REDIRECT_URL=http://127.0.0.1:8080/kite/callback
# Optional: where to send the browser after OAuth (defaults to first CORS origin).
# KITE_POST_LOGIN_REDIRECT=http://localhost:5173

# DASHBOARD_RESTART_BOT_ON_SAVE=1
