FROM node:20-alpine AS build
WORKDIR /app

COPY src/client/package.json src/client/package-lock.json ./
RUN npm ci

COPY src/client/ ./
# Empty = same-origin (UI nginx proxies /api and /ws to the API container).
ARG VITE_DASHBOARD_API_BASE=
ENV VITE_DASHBOARD_API_BASE=$VITE_DASHBOARD_API_BASE
RUN npm run build

FROM nginx:alpine
COPY configs/docker/nginx.default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
