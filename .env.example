# Repo root — used by docker compose for the `api` service. Copy to `.env` (never commit).

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

# First-time seed only: if users_auth.json has no AK07 row yet, this sets the password hash.
# After the first user file exists, change the password by editing server/data/users_auth.json on the volume
# or temporarily remove that file and recreate with a new AK07_PASSWORD.
AK07_PASSWORD=change-me-rotate-for-production

# Trading bot HTTP posts must send this header when not calling from loopback inside the api container.
BOT_API_TOKEN=change-me-shared-secret-for-trading-bot

# Browser origins allowed for CORS (direct API access). When using the bundled UI nginx, same-origin calls
# do not hit CORS, but keep your public site origin here if you ever split hosts.
DASHBOARD_CORS_ORIGINS=https://ak07.in,http://ak07.in,http://localhost:8080,http://127.0.0.1:8080

# In Docker, default is 0 (compose sets DASHBOARD_RESTART_BOT_ON_SAVE). Enable on the host if trading_bot runs beside the stack.
# DASHBOARD_RESTART_BOT_ON_SAVE=1
