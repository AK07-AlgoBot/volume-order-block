# Zerodha Kite Connect — create app at https://developers.kite.trade/
# Copy this file to .env and fill values (never commit .env).

KITE_API_KEY=
KITE_API_SECRET=

# Must match exactly what you registered in the Kite developer console.
KITE_REDIRECT_URL=http://127.0.0.1:8080/kite/callback

# Random long string for signing session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# API server bind (default 8080 to match redirect URL port)
HOST=127.0.0.1
PORT=8080
