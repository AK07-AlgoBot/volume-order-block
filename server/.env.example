# Copy to server/.env (do not commit .env)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480
BOT_API_TOKEN=change-me-shared-secret-for-trading-bot

# Comma-separated origins for browser clients
DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: require this header for Upstox POST in addition to admin JWT (legacy)
# DASHBOARD_ADMIN_TOKEN=
