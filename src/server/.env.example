# Copy to src/server/.env for local uvicorn. For Docker, copy configs/.env.example to repo root `.env`.

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480
BOT_API_TOKEN=change-me-shared-secret-for-trading-bot
# Trading day end in IST; bot auto-shutdown/archive starts after this time (HH:MM).
# TRADING_DAILY_SHUTDOWN_TIME=23:21

# First-time seed for AK07 login when users_auth.json is created (see app/services/users_store.py).
AK07_PASSWORD=admin

DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://ak07.in,http://ak07.in

# Kite Connect OAuth — same app as https://developers.kite.trade/ (redirect must match console exactly).
# KITE_REDIRECT_URL example: http://127.0.0.1:8080/kite/callback (API host/port where uvicorn runs).
# KITE_POST_LOGIN_REDIRECT optional; defaults to first DASHBOARD_CORS_ORIGINS origin (e.g. Vite :5173).
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_REDIRECT_URL=http://127.0.0.1:8080/kite/callback
# KITE_POST_LOGIN_REDIRECT=http://127.0.0.1:5173/
