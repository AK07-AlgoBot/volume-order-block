# Copy to src/server/.env for local uvicorn. For Docker, copy configs/.env.example to repo root `.env`.

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480
BOT_API_TOKEN=change-me-shared-secret-for-trading-bot

# First-time seed for AK07 login when users_auth.json is created (see app/services/users_store.py).
AK07_PASSWORD=change-me-use-a-strong-password

DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://ak07.in,http://ak07.in
